{
	"name": "@boelabs/unified-gateway",
	"version": "0.1.0",
	"description": "Provider-agnostic AI gateway with an exact OpenAI-compatible contract. Backend only.",
	"license": "MIT",
	"author": "Boelabs",
	"type": "module",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/boelabs/unified-gateway.git",
		"directory": "apps/gateway"
	},
	"bugs": {
		"url": "https://github.com/boelabs/unified-gateway/issues"
	},
	"homepage": "https://github.com/boelabs/unified-gateway#readme",
	"keywords": [
		"ai",
		"gateway",
		"openai",
		"anthropic",
		"gemini",
		"llm",
		"router"
	],
	"engines": {
		"bun": ">=1.3"
	},
	"imports": {
		"#test-support/*": "./tests/support/*",
		"#*": "./src/*"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun run test:unit",
		"test:unit": "bun test --preload ./tests/support/unitSetup.ts src tests/support",
		"test:integration": "bun scripts/run-integration.ts",
		"test:all": "bun run test:unit && bun run test:integration",
		"catalog:validate": "bun scripts/validate-catalog.ts",
		"catalog:sync": "bun scripts/catalog-sync.ts",
		"catalog:sync:verify": "bun scripts/catalog-sync.ts --mode verify",
		"openapi:generate": "bun scripts/openapi-generate.ts",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "bun src/db/migrate.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "3.1079.0",
		"@aws-sdk/lib-storage": "^3.1079.0",
		"@hono/node-server": "2.0.6",
		"@opentelemetry/api": "1.9.1",
		"@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
		"@opentelemetry/exporter-trace-otlp-http": "0.219.0",
		"@opentelemetry/instrumentation-http": "0.219.0",
		"@opentelemetry/resources": "2.8.0",
		"@opentelemetry/sdk-metrics": "2.8.0",
		"@opentelemetry/sdk-node": "0.219.0",
		"@t3-oss/env-core": "0.13.11",
		"busboy": "1.6.0",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.27",
		"ioredis": "5.11.1",
		"postgres": "3.4.9",
		"sharp": "0.35.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@boelabs/tsconfig": "workspace:*",
		"@types/busboy": "1.5.4",
		"@types/node": "26.0.1",
		"drizzle-kit": "0.31.10",
		"typescript": "6.0.3",
		"yaml": "2.9.0",
		"zod-openapi": "6.0.0"
	}
}

					},
					"maxInputTokens": 262144,
					"maxOutputTokens": 32768,
					"reasoning": {
						"kind": "openai_body",
						"levels": ["none", "high"],
						"bodyField": {
							"param": "thinking",
							"onValue": {
								"type": "enabled"
							},
							"offValue": {
								"type": "disabled"
							}
						}
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled", "disabled"]
						},
						"frequency_penalty": true,
						"include_reasoning": true,
						"max_tokens": true,
						"presence_penalty": true,
						"reasoning": true,
						"response_format": true,
						"stop": true,
						"structured_outputs": true,
						"tool_choice": true,
						"tools": true,
						"temperature": true,
						"top_p": true,
						"logprobs": true,
						"top_logprobs": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 60,
				"outputCentsPerMTokens": 300,
				"cacheReadCentsPerMTokens": 10
			}
		},
		"kimi-latest": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": true,
						"reasoning": false,
						"structuredOutputs": false
					},
					"maxInputTokens": 131072,
					"maxOutputTokens": 16384
				}
			}
		},
		"kimi-k2": {
			"operations": {
				"text.generate": {
					"maxInputTokens": 131072,

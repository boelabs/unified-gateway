			}
		},
		"kimi-k2-thinking": {
			"operations": {
				"text.generate": {
					"parameters": {
						"max_tokens": true,
						"temperature": true,
						"stop": true,
						"tools": true,
						"tool_choice": true,
						"reasoning": true,
						"include_reasoning": true,
						"top_p": true,
						"top_k": true,
						"min_p": true,
						"frequency_penalty": true,

						"top_p": true,
						"frequency_penalty": true,
						"presence_penalty": true,
						"seed": true,
						"top_k": true,
						"repetition_penalty": true
					},
					"capabilities": {
						"tools": true,
						"vision": false,
						"structuredOutputs": false
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 57,

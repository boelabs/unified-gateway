{
	"$schema": "../../../schemas/model-catalog.schema.json",
	"schemaVersion": 1,
	"provider": {
		"id": "moonshot",
		"adapterKey": "moonshot",
		"name": "Moonshot AI / Kimi",
		"docs": [
			"https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart.md",
			"https://platform.kimi.ai/docs/guide/kimi-k2-7-code-quickstart.md",
			"https://platform.kimi.ai/docs/api/chat.md",
			"https://platform.kimi.ai/docs/pricing/chat-k26.md",
			"https://platform.kimi.ai/docs/pricing/chat-k27-code.md",
			"https://platform.kimi.ai/docs/pricing/chat.md"
		]
	},
	"models": {
		"kimi-k2.7-code": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": true,
						"reasoning": true,
						"structuredOutputs": true
					},
					"maxInputTokens": 262144,
					"maxOutputTokens": 32768,
					"reasoning": {
						"kind": "fixed",
						"levels": ["high"]
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled"],
							"notes": "Kimi K2.7 Code is always thinking; disabling thinking returns an error."
						},
						"temperature": {
							"mode": "mapped",
							"values": [1],
							"notes": "Fixed at 1.0; other values return an error."
						},
						"top_p": {
							"mode": "mapped",
							"values": [0.95]
						},
						"tool_choice": {
							"mode": "supported",
							"values": ["auto", "none"],
							"notes": "Thinking mode only supports auto or none."
						},
						"frequency_penalty": true,
						"include_reasoning": true,
						"max_tokens": true,
						"presence_penalty": true,
						"reasoning": true,
						"response_format": true,
						"stop": true,
						"structured_outputs": true,
						"tools": true,
						"repetition_penalty": true,
						"top_k": true,
						"seed": true,
						"min_p": true,
						"logit_bias": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 95,
				"outputCentsPerMTokens": 400,
				"cacheReadCentsPerMTokens": 19
			}
		},
		"kimi-k2.7-code-highspeed": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": true,
						"reasoning": true,
						"structuredOutputs": true
					},
					"maxInputTokens": 262144,
					"maxOutputTokens": 32768,
					"reasoning": {
						"kind": "fixed",
						"levels": ["high"]
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled"],
							"notes": "HighSpeed uses the same model/parameters as Kimi K2.7 Code and cannot disable thinking."
						},
						"temperature": {
							"mode": "mapped",
							"values": [1]
						},
						"top_p": {
							"mode": "mapped",
							"values": [0.95]
						},
						"tool_choice": {
							"mode": "supported",
							"values": ["auto", "none"]
						},
						"max_tokens": true,
						"stop": true,
						"tools": true,
						"reasoning": true,
						"include_reasoning": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 190,
				"outputCentsPerMTokens": 800,
				"cacheReadCentsPerMTokens": 38
			}
		},
		"kimi-k2.6": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": true,
						"reasoning": true,
						"structuredOutputs": true
					},
					"maxInputTokens": 262144,
					"maxOutputTokens": 262144,
					"reasoning": {
						"kind": "openai_body",
						"levels": ["none", "high"],
						"bodyField": {
							"param": "thinking",
							"onValue": {
								"type": "enabled"
							},
							"offValue": {
								"type": "disabled"
							}
						}
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled", "disabled"]
						},
						"temperature": {
							"mode": "mapped",
							"values": [1, 0.6],
							"notes": "Thinking mode uses fixed 1.0; non-thinking mode uses fixed 0.6."
						},
						"top_p": {
							"mode": "mapped",
							"values": [0.95]
						},
						"tool_choice": {
							"mode": "supported",
							"values": ["auto", "none"],
							"notes": "With thinking enabled, tool_choice is limited to auto or none."
						},
						"frequency_penalty": true,
						"include_reasoning": true,
						"max_tokens": true,
						"presence_penalty": true,
						"reasoning": true,
						"response_format": true,
						"stop": true,
						"structured_outputs": true,
						"tools": true,
						"logprobs": true,
						"top_logprobs": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 95,
				"outputCentsPerMTokens": 400,
				"cacheReadCentsPerMTokens": 16
			}
		},

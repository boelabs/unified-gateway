{
	"$schema": "../../../schemas/model-catalog.schema.json",
	"schemaVersion": 1,
	"provider": {
		"id": "deepseek",
		"adapterKey": "deepseek",
		"name": "DeepSeek",
		"docs": [
			"https://api-docs.deepseek.com/quick_start/pricing",
			"https://api-docs.deepseek.com/api/create-chat-completion",
			"https://api-docs.deepseek.com/guides/thinking_mode"
		]
	},
	"models": {
		"deepseek-v4-flash": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": false,
						"reasoning": true,
						"structuredOutputs": false
					},
					"maxInputTokens": 1000000,
					"maxOutputTokens": 384000,
					"reasoning": {
						"kind": "openai_body",
						"levels": ["none", "high", "max"],
						"bodyField": {
							"param": "thinking",
							"onValue": {
								"type": "enabled"
							},
							"offValue": {
								"type": "disabled"
							}
						},
						"effortField": "reasoning_effort"
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled", "disabled"],
							"notes": "Thinking defaults to enabled upstream; the gateway emits disabled when public effort is none."
						},
						"reasoning_effort": {
							"mode": "mapped",
							"values": ["high", "max"],
							"notes": "DeepSeek supports native high/max; canonical xhigh stays distinct and snaps down to high."
						},
						"temperature": {
							"mode": "ignored",
							"notes": "Thinking mode does not use sampling parameters."
						},
						"frequency_penalty": true,
						"include_reasoning": true,
						"logprobs": true,
						"max_tokens": true,
						"presence_penalty": true,
						"reasoning": true,
						"response_format": true,
						"stop": true,
						"tool_choice": true,
						"tools": true,
						"top_logprobs": true,
						"top_p": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 14,
				"outputCentsPerMTokens": 28,
				"cacheReadCentsPerMTokens": 0.28
			}
		},

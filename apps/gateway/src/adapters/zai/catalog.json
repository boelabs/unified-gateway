		"glm-5.2": {
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": false,
						"reasoning": true,
						"structuredOutputs": true
					},
					"maxInputTokens": 1000000,
					"maxOutputTokens": 131072,
					"reasoning": {
						"kind": "openai_body",
						"levels": ["none", "minimal", "low", "medium", "high", "xhigh"],
						"upstreamEffortMap": {
							"minimal": "none",
							"low": "high",
							"medium": "high",
							"xhigh": "max"
						},
						"bodyField": {
							"param": "thinking",
							"onValue": {
								"type": "enabled"
							},
							"offValue": {
								"type": "disabled"
							}
						},
						"effortField": "reasoning_effort"
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled", "disabled"]
						},
						"reasoning_effort": {
							"mode": "mapped",
							"values": [
								"max",
								"xhigh",
								"high",
								"medium",
								"low",
								"minimal",
								"none"
							],
							"notes": "Z.AI maps low/medium to high, xhigh to max, and none/minimal skip thinking."
						},
						"include_reasoning": true,
						"max_tokens": true,
						"reasoning": true,
						"response_format": true,
						"temperature": true,
						"tool_choice": true,
						"tools": true,
						"top_k": true,
						"top_p": true,
						"stop": true,
						"frequency_penalty": true,
						"presence_penalty": true,
						"repetition_penalty": true,
						"seed": true,
						"min_p": true,
						"logit_bias": true,
						"structured_outputs": true
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 140,
				"outputCentsPerMTokens": 440,
				"cacheReadCentsPerMTokens": 26,
				"cacheWriteCentsPerMTokens": 0
			}
		},

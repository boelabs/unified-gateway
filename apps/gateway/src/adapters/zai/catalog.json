	"models": {
		"glm-5.2": {
			"name": "GLM-5.2",
			"family": "glm-5",
			"openWeights": true,
			"modalities": {
				"input": ["text"],
				"output": ["text"]
			},
			"operations": {
				"text.generate": {
					"capabilities": {
						"tools": true,
						"vision": false,
						"reasoning": true,
						"structuredOutputs": true
					},
					"maxInputTokens": 1000000,
					"maxOutputTokens": 131072,
					"reasoning": {
						"kind": "openai_body",
						"levels": ["minimal", "low", "medium", "high", "xhigh"],
						"canDisable": true,
						"upstreamEffortMap": {
							"minimal": "none",
							"low": "high",
							"medium": "high",
							"xhigh": "max"
						},
						"bodyField": {
							"param": "thinking",
							"onValue": { "type": "enabled" },
							"offValue": { "type": "disabled" }
						},
						"effortField": "reasoning_effort"
					},
					"contracts": ["chat.completions"],
					"parameters": {
						"thinking": {
							"mode": "supported",
							"upstreamField": "thinking",
							"values": ["enabled", "disabled"]
						},
						"reasoning_effort": {
							"mode": "mapped",
							"values": [
								"max",
								"xhigh",
								"high",
								"medium",
								"low",
								"minimal",
								"none"
							],
							"notes": "Z.AI maps low/medium to high, xhigh to max, and none/minimal skip thinking."
						}
					}
				}
			},
			"pricing": {
				"inputCentsPerMTokens": 140,
				"outputCentsPerMTokens": 440,
				"cacheReadCentsPerMTokens": 26
			},
			"sources": [
				"https://docs.z.ai/guides/llm/glm-5.2.md",
				"https://docs.z.ai/guides/overview/concept-param.md"
			],
			"lastVerifiedAt": "2026-06-24"
		},

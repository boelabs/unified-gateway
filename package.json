{
	"name": "unified-gateway",
	"version": "0.1.0",
	"description": "Unified Gateway by Boelabs — the gateway service, its docs site, and shared packages.",
	"license": "MIT",
	"author": "Boelabs",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"engines": {
		"node": ">=24",
		"bun": ">=1.3"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"overrides": {
		"sharp": "0.35.3"
	},
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"typecheck": "turbo run typecheck && tsc --noEmit -p tsconfig.json",
		"test": "turbo run test",
		"test:all": "turbo run test:all",
		"lint": "biome lint .",
		"format": "biome format --write . && bun scripts/sort-imports.ts",
		"check": "biome check . --diagnostic-level=warn --error-on-warnings --max-diagnostics=100",
		"check:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@boelabs/tsconfig": "workspace:*",
		"@types/node": "26.1.0",
		"turbo": "2.10.4",
		"typescript": "6.0.3"
	}
}
